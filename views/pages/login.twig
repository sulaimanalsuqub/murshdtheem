{% extends "layouts/master.twig" %}

{% block content %}

    <section class="section" style="min-height:70vh;display:flex;align-items:center">
        <div class="container">
            <div class="auth-wrapper">
                <div class="auth-box">
                    {# Logo #}
                    <div style="text-align:center;margin-bottom:32px">
                        <a href="/" class="logo" style="justify-content:center">
                            <div class="logo-icon" style="width:48px;height:48px;font-size:1.4rem">م</div>
                        </a>
                        <h1 class="auth-title">مرحباً بعودتك</h1>
                        <p class="auth-subtitle">سجل دخولك للوصول لمنتجاتك الرقمية</p>
                    </div>

                    {# Login Form #}
                    <form class="auth-form">
                        <div class="form-group">
                            <label class="form-label">البريد الإلكتروني أو رقم الجوال</label>
                            <div class="input-icon-wrap">
                                <i class="ri-mail-line input-icon"></i>
                                <input type="text" class="form-input form-input-icon" placeholder="example@email.com" required>
                            </div>
                        </div>
                        <div class="form-group">
                            <div style="display:flex;justify-content:space-between;align-items:center">
                                <label class="form-label">كلمة المرور</label>
                                <a href="/password/reset" class="form-link">نسيت كلمة المرور؟</a>
                            </div>
                            <div class="input-icon-wrap">
                                <i class="ri-lock-line input-icon"></i>
                                <input type="password" class="form-input form-input-icon" placeholder="••••••••" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg" style="width:100%;margin-top:8px">
                            تسجيل الدخول
                        </button>
                    </form>

                    {# Divider #}
                    <div class="auth-divider">
                        <span>أو</span>
                    </div>

                    {# Social Login #}
                    <div style="display:flex;flex-direction:column;gap:12px">
                        <button class="btn btn-social">
                            <i class="ri-google-fill"></i>
                            الدخول بحساب Google
                        </button>
                        <button class="btn btn-social">
                            <i class="ri-apple-fill"></i>
                            الدخول بحساب Apple
                        </button>
                    </div>

                    {# Register Link #}
                    <p class="auth-footer">
                        ليس لديك حساب؟ <a href="/register" class="auth-link">إنشاء حساب جديد</a>
                    </p>
                </div>
            </div>
        </div>
    </section>

{% endblock %}
