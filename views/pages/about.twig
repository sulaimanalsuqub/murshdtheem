{% extends "layouts/master.twig" %}

{% block content %}

    {# Page Header #}
    <div class="page-header">
        <div class="container">
            <h1 class="page-title">من نحن</h1>
            <div class="breadcrumb">
                <a href="/">الرئيسية</a>
                <span class="separator"><i class="ri-arrow-left-s-line"></i></span>
                <span>من نحن</span>
            </div>
        </div>
    </div>

    {# About Content #}
    <section class="section">
        <div class="container">
            <div class="about-grid">
                <div class="about-content">
                    <div class="hero-badge" style="margin-bottom:20px">
                        <i class="ri-sparkle-line"></i>
                        <span>قصتنا</span>
                    </div>
                    <h2 class="about-title">نساعدك على التميز بمنتجات رقمية <span style="color:var(--primary)">احترافية</span></h2>
                    <p class="about-desc">
                        نؤمن بأن كل شخص يستحق الوصول لأدوات احترافية تساعده على النجاح. لذلك أسسنا متجرنا ليكون وجهتك الأولى للمنتجات الرقمية عالية الجودة بأسعار عادلة.
                    </p>
                    <p class="about-desc">
                        فريقنا من المصممين والمطورين يعمل بشغف لتقديم منتجات مميزة تلبي احتياجاتك وتتجاوز توقعاتك.
                    </p>
                </div>
                <div class="about-image">
                    <div style="width:100%;height:400px;background:linear-gradient(135deg,var(--primary),var(--accent));border-radius:var(--radius-xl);display:flex;align-items:center;justify-content:center">
                        <i class="ri-team-line" style="font-size:5rem;color:#fff;opacity:0.3"></i>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# Values #}
    <section class="section" style="background:#fff">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title">قيمنا</h2>
                <p class="section-subtitle">المبادئ التي نعمل بها يومياً</p>
            </div>
            <div class="features-grid" style="grid-template-columns:repeat(4,1fr)">
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-award-line"></i></div>
                    <h3 class="feature-title">الجودة أولاً</h3>
                    <p class="feature-desc">لا نقبل بأقل من أعلى معايير الجودة في كل منتج نقدمه</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-hand-heart-line"></i></div>
                    <h3 class="feature-title">رضا العميل</h3>
                    <p class="feature-desc">عملاؤنا هم أولويتنا ونسعى دائماً لتجاوز توقعاتهم</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-lightbulb-line"></i></div>
                    <h3 class="feature-title">الإبداع</h3>
                    <p class="feature-desc">نبتكر حلولاً جديدة ومميزة تواكب أحدث التوجهات</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-shield-star-line"></i></div>
                    <h3 class="feature-title">الموثوقية</h3>
                    <p class="feature-desc">نلتزم بوعودنا ونقدم دعماً متواصلاً لعملائنا</p>
                </div>
            </div>
        </div>
    </section>

    {# Stats #}
    <section class="section">
        <div class="container">
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-value">+500</div>
                    <div class="stat-label">منتج رقمي</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">+2000</div>
                    <div class="stat-label">عميل سعيد</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">+10,000</div>
                    <div class="stat-label">عملية تحميل</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value">4.9</div>
                    <div class="stat-label">تقييم العملاء</div>
                </div>
            </div>
        </div>
    </section>

    {# CTA #}
    <section class="cta-section">
        <div class="container">
            <div class="cta-box">
                <h2 class="cta-title">جاهز للبدء؟</h2>
                <p class="cta-desc">تصفح مجموعتنا المتنوعة من المنتجات الرقمية واختر ما يناسبك</p>
                <a href="/products" class="cta-btn"><i class="ri-shopping-bag-line"></i> تصفح المنتجات</a>
            </div>
        </div>
    </section>

{% endblock %}
