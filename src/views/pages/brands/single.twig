{% extends "layouts/master.twig" %}

{% block content %}

    <div class="page-header">
        <div class="container">
            <h1 class="page-title">{{ brand.name }}</h1>
            <div class="breadcrumb">
                <a href="/">الرئيسية</a>
                <span class="separator"><i class="ri-arrow-left-s-line"></i></span>
                <a href="/brands">العلامات التجارية</a>
                <span class="separator"><i class="ri-arrow-left-s-line"></i></span>
                <span>{{ brand.name }}</span>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="container">
            {# Brand Info #}
            <div style="display:flex;align-items:center;gap:24px;margin-bottom:48px;padding:32px;background:var(--bg-card);border-radius:var(--radius-lg);border:1px solid var(--border)">
                {% if brand.logo %}
                    <img src="{{ brand.logo }}" alt="{{ brand.name }}" style="width:100px;height:100px;object-fit:contain;border-radius:var(--radius-md)">
                {% else %}
                    <div style="width:100px;height:100px;border-radius:var(--radius-md);background:linear-gradient(135deg,rgba(108,92,231,0.1),rgba(0,206,201,0.1));display:flex;align-items:center;justify-content:center;font-size:2.5rem;color:var(--primary);flex-shrink:0">
                        <i class="ri-building-line"></i>
                    </div>
                {% endif %}
                <div>
                    <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:8px">{{ brand.name }}</h2>
                    {% if brand.description %}
                        <p style="color:var(--text-light);line-height:1.7">{{ brand.description }}</p>
                    {% endif %}
                </div>
            </div>

            {# Brand Products #}
            {% if products|length > 0 %}
                <div class="products-grid">
                    {% for product in products %}
                        {% include 'components/product-card.twig' with {product: product} %}
                    {% endfor %}
                </div>

                {% if pagination %}
                    <div style="display:flex;justify-content:center;gap:8px;margin-top:48px">
                        {% if pagination.prev_page %}
                            <a href="{{ pagination.prev_page }}" class="btn btn-outline"><i class="ri-arrow-right-line"></i> السابق</a>
                        {% endif %}
                        {% if pagination.next_page %}
                            <a href="{{ pagination.next_page }}" class="btn btn-primary">التالي <i class="ri-arrow-left-line"></i></a>
                        {% endif %}
                    </div>
                {% endif %}
            {% else %}
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="ri-shopping-bag-line"></i></div>
                    <h3 class="empty-state-title">لا توجد منتجات لهذه العلامة التجارية</h3>
                    <a href="/products" class="btn btn-primary">تصفح جميع المنتجات</a>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
