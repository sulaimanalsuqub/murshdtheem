{% extends "layouts/master.twig" %}

{% block content %}

    {# ===== Dynamic Home Components (configured from Salla dashboard) ===== #}
    {% for position, component in components %}
        {% component 'home.' ~ component.path with {component: component, position: position} %}
    {% endfor %}

    {# ===== Featured Products (fallback if no components configured) ===== #}
    {% if not components|length %}
        <section class="murshd-section">
            <div class="container">
                <div class="murshd-section__header">
                    <h2 class="murshd-section__title">{{ trans('blocks.home.products') }}</h2>
                </div>
                <salla-products-list></salla-products-list>
            </div>
        </section>
    {% endif %}

{% endblock %}
