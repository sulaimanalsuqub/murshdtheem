{% extends "layouts/master.twig" %}

{% block content %}

    <div class="page-header">
        <div class="container">
            <h1 class="page-title">برنامج الولاء</h1>
            <div class="breadcrumb">
                <a href="/">الرئيسية</a>
                <span class="separator"><i class="ri-arrow-left-s-line"></i></span>
                <span>برنامج الولاء</span>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="container">
            {# Points Overview #}
            <div class="loyalty-hero" style="background:linear-gradient(135deg,var(--primary),#8B7CF8);border-radius:var(--radius-xl);padding:48px;text-align:center;color:#fff;margin-bottom:48px;position:relative;overflow:hidden">
                <div style="position:relative;z-index:1">
                    <div style="width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:2rem">
                        <i class="ri-vip-crown-line"></i>
                    </div>
                    <h2 style="font-size:1.8rem;font-weight:700;margin-bottom:8px">رصيد نقاطك</h2>
                    <div style="font-size:3rem;font-weight:700;margin-bottom:8px">
                        {{ loyalty.points|default('0') }}
                        <span style="font-size:1rem;opacity:0.8">نقطة</span>
                    </div>
                    <p style="opacity:0.8">تساوي {{ loyalty.points_value|default('0') }} {{ store.currency|default('ر.س') }}</p>
                </div>
            </div>

            {# How it works #}
            <div class="section-header">
                <h2 class="section-title">كيف يعمل برنامج الولاء؟</h2>
                <p class="section-subtitle">اجمع النقاط واستبدلها بخصومات مميزة</p>
            </div>

            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-shopping-bag-line"></i></div>
                    <h3 class="feature-title">اشترِ المنتجات</h3>
                    <p class="feature-desc">اكسب نقاط مع كل عملية شراء تقوم بها من متجرنا</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-coin-line"></i></div>
                    <h3 class="feature-title">اجمع النقاط</h3>
                    <p class="feature-desc">كلما زادت مشترياتك، زاد رصيد نقاطك</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon"><i class="ri-gift-line"></i></div>
                    <h3 class="feature-title">استبدل بخصومات</h3>
                    <p class="feature-desc">استخدم نقاطك للحصول على خصومات على مشترياتك القادمة</p>
                </div>
            </div>

            {# Points History #}
            {% if loyalty.history|length > 0 %}
                <div style="margin-top:64px">
                    <h2 class="section-title" style="text-align:right;margin-bottom:24px">سجل النقاط</h2>
                    <div style="display:flex;flex-direction:column;gap:12px">
                        {% for entry in loyalty.history %}
                            <div class="cart-item">
                                <div style="width:44px;height:44px;border-radius:var(--radius-sm);background:{% if entry.type == 'earned' %}rgba(0,206,201,0.1){% else %}rgba(108,92,231,0.1){% endif %};display:flex;align-items:center;justify-content:center;flex-shrink:0">
                                    <i class="{% if entry.type == 'earned' %}ri-add-line{% else %}ri-subtract-line{% endif %}" style="color:{% if entry.type == 'earned' %}var(--accent){% else %}var(--primary){% endif %};font-size:1.2rem"></i>
                                </div>
                                <div class="cart-item-info">
                                    <h3 class="cart-item-name">{{ entry.description }}</h3>
                                    <span class="cart-item-type">{{ entry.date }}</span>
                                </div>
                                <div style="font-weight:700;color:{% if entry.type == 'earned' %}var(--accent){% else %}var(--primary){% endif %}">
                                    {% if entry.type == 'earned' %}+{% else %}-{% endif %}{{ entry.points }} نقطة
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
