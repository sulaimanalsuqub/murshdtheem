{% extends "layouts/master.twig" %}

{% block content %}

    {# Page Header #}
    <div class="page-header">
        <div class="container">
            <h1 class="page-title">سلة المشتريات</h1>
            <div class="breadcrumb">
                <a href="/">الرئيسية</a>
                <span class="separator"><i class="ri-arrow-left-s-line"></i></span>
                <span>سلة المشتريات</span>
            </div>
        </div>
    </div>

    <section class="cart-page">
        <div class="container">
            {% if cart.items|length > 0 %}
                <div class="cart-grid">
                    {# Cart Items #}
                    <div class="cart-items">
                        {% for item in cart.items %}
                            <div class="cart-item" id="cart-item-{{ item.id }}">
                                <div class="cart-item-image">
                                    <img src="{{ item.product.image.url }}" alt="{{ item.product.name }}">
                                </div>
                                <div class="cart-item-info">
                                    <h3 class="cart-item-name">{{ item.product.name }}</h3>
                                    <span class="cart-item-type">
                                        <i class="ri-file-download-line"></i> منتج رقمي
                                    </span>
                                </div>
                                <div class="cart-item-price">
                                    {{ item.price }} {{ item.currency|default('ر.س') }}
                                </div>
                                <button class="cart-item-remove" onclick="salla.cart.deleteItem({{ item.id }})" aria-label="حذف">
                                    <i class="ri-delete-bin-line"></i>
                                </button>
                            </div>
                        {% endfor %}
                    </div>

                    {# Cart Summary #}
                    <div class="cart-summary">
                        <h3 class="cart-summary-title">ملخص الطلب</h3>
                        <div class="cart-summary-row">
                            <span class="label">المجموع الفرعي</span>
                            <span class="value">{{ cart.sub_total }} {{ cart.currency|default('ر.س') }}</span>
                        </div>
                        {% if cart.discount %}
                            <div class="cart-summary-row">
                                <span class="label">الخصم</span>
                                <span class="value" style="color:var(--accent)">- {{ cart.discount }} {{ cart.currency|default('ر.س') }}</span>
                            </div>
                        {% endif %}
                        {% if cart.tax %}
                            <div class="cart-summary-row">
                                <span class="label">الضريبة</span>
                                <span class="value">{{ cart.tax }} {{ cart.currency|default('ر.س') }}</span>
                            </div>
                        {% endif %}
                        <div class="cart-summary-total">
                            <span>الإجمالي</span>
                            <span class="value">{{ cart.total }} {{ cart.currency|default('ر.س') }}</span>
                        </div>

                        {# Coupon #}
                        <div style="margin-top:20px; display:flex; gap:8px">
                            <input type="text" id="couponCode" placeholder="كود الخصم"
                                style="flex:1; padding:12px 16px; border:1px solid var(--border); border-radius:var(--radius-sm); font-family:var(--font)">
                            <button class="btn btn-outline" onclick="salla.cart.applyCoupon(document.getElementById('couponCode').value)">
                                تطبيق
                            </button>
                        </div>

                        <a href="/checkout" class="btn btn-primary checkout-btn">
                            <i class="ri-lock-line"></i>
                            إتمام الشراء
                        </a>
                    </div>
                </div>
            {% else %}
                <div class="empty-state">
                    <div class="empty-state-icon">
                        <i class="ri-shopping-bag-line"></i>
                    </div>
                    <h3 class="empty-state-title">سلة المشتريات فارغة</h3>
                    <p class="empty-state-desc">ابدأ بتصفح منتجاتنا الرقمية وأضف ما يعجبك!</p>
                    <a href="/products" class="btn btn-primary btn-lg">
                        <i class="ri-shopping-bag-line"></i>
                        تصفح المنتجات
                    </a>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
