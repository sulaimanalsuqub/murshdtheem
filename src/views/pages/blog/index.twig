{% extends "layouts/master.twig" %}

{% block content %}

    <div class="page-header">
        <div class="container">
            <h1 class="page-title">المدونة</h1>
            <div class="breadcrumb">
                <a href="/">الرئيسية</a>
                <span class="separator"><i class="ri-arrow-left-s-line"></i></span>
                <span>المدونة</span>
            </div>
        </div>
    </div>

    <section class="section">
        <div class="container">
            {% if posts|length > 0 %}
                <div class="blog-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:24px">
                    {% for post in posts %}
                        <article class="blog-card" style="background:var(--bg-card);border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--border);transition:var(--transition)">
                            <a href="{{ post.url }}" style="display:block;aspect-ratio:16/9;overflow:hidden;background:linear-gradient(135deg,#F8F7FF,#F0EFFF)">
                                {% if post.image %}
                                    <img src="{{ post.image.url }}" alt="{{ post.title }}" style="width:100%;height:100%;object-fit:cover;transition:var(--transition)">
                                {% else %}
                                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--primary-light);font-size:3rem">
                                        <i class="ri-article-line"></i>
                                    </div>
                                {% endif %}
                            </a>
                            <div style="padding:24px">
                                <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;font-size:0.8rem;color:var(--text-muted)">
                                    <span><i class="ri-calendar-line"></i> {{ post.date }}</span>
                                    {% if post.category %}
                                        <span style="color:var(--primary);font-weight:500">{{ post.category.name }}</span>
                                    {% endif %}
                                </div>
                                <h2 style="font-size:1.1rem;font-weight:600;margin-bottom:10px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">
                                    <a href="{{ post.url }}">{{ post.title }}</a>
                                </h2>
                                <p style="font-size:0.9rem;color:var(--text-light);line-height:1.7;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
                                    {{ post.excerpt|default(post.content|striptags|slice(0, 150)) }}
                                </p>
                                <a href="{{ post.url }}" style="display:inline-flex;align-items:center;gap:4px;margin-top:16px;font-size:0.9rem;font-weight:500;color:var(--primary)">
                                    اقرأ المزيد <i class="ri-arrow-left-line"></i>
                                </a>
                            </div>
                        </article>
                    {% endfor %}
                </div>

                {% if pagination %}
                    <div style="display:flex;justify-content:center;gap:8px;margin-top:48px">
                        {% if pagination.prev_page %}
                            <a href="{{ pagination.prev_page }}" class="btn btn-outline"><i class="ri-arrow-right-line"></i> السابق</a>
                        {% endif %}
                        {% if pagination.next_page %}
                            <a href="{{ pagination.next_page }}" class="btn btn-primary">التالي <i class="ri-arrow-left-line"></i></a>
                        {% endif %}
                    </div>
                {% endif %}
            {% else %}
                <div class="empty-state">
                    <div class="empty-state-icon"><i class="ri-article-line"></i></div>
                    <h3 class="empty-state-title">لا توجد مقالات حالياً</h3>
                    <p class="empty-state-desc">سيتم إضافة مقالات جديدة قريباً</p>
                    <a href="/" class="btn btn-primary">العودة للرئيسية</a>
                </div>
            {% endif %}
        </div>
    </section>

{% endblock %}
