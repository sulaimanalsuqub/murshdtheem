<header class="header {{ theme.settings.get('header_is_sticky') ? 'is-sticky' : '' }} {{ theme.settings.get('topnav_is_dark') ? 'header--dark' : '' }}" id="mainnav">
    <div class="container">
        <div class="header-inner">

            {# Logo #}
            <a href="{{ store.url }}" class="logo" aria-label="{{ store.name }}">
                {% if store.logo %}
                    <img src="{{ store.logo }}" alt="{{ store.name }}" class="logo-img" width="120" height="40">
                {% else %}
                    <span class="logo-text">{{ store.name }}</span>
                {% endif %}
            </a>

            {# Navigation #}
            <nav class="nav" id="mainNav" aria-label="القائمة الرئيسية">
                {% component 'header.nav-menu' %}
            </nav>

            {# Actions #}
            <div class="header-actions">
                <salla-search show-btn></salla-search>
                <salla-cart-summary></salla-cart-summary>
                <salla-user-menu></salla-user-menu>

                {# Mobile Toggle #}
                <button class="menu-toggle" id="menuToggle" aria-label="القائمة" aria-expanded="false" aria-controls="mainNav">
                    <i class="sicon-menu-right"></i>
                </button>
            </div>

        </div>
    </div>
</header>
