{#
| product | Product
#}
<div class="murshd-product-card">
    {% if product.promotion_title %}
        <span class="murshd-product-badge">{{ product.promotion_title }}</span>
    {% endif %}

    <a href="{{ product.url }}" class="murshd-product-image" aria-label="{{ product.name }}">
        <img src="{{ product.thumbnail ?? product.image.url }}"
             alt="{{ product.name }}"
             loading="lazy"
             width="400" height="400">
        <div class="murshd-product-overlay">
            <salla-wishlist-btn product-id="{{ product.id }}"
                                class="overlay-btn"
                                aria-label="{{ trans('pages.wishlist.add') }}">
            </salla-wishlist-btn>
        </div>
    </a>

    <div class="murshd-product-info">
        {% if product.category %}
            <span class="murshd-product-category">{{ product.category.name }}</span>
        {% endif %}
        <h3 class="murshd-product-name">
            <a href="{{ product.url }}">{{ product.name }}</a>
        </h3>

        <div class="murshd-product-footer">
            <salla-price
                class="murshd-product-price"
                amount="{{ product.price }}"
                old-amount="{{ product.sale_price ? product.regular_price : '' }}"
                currency="{{ product.currency }}">
            </salla-price>

            <salla-add-product-button
                product-id="{{ product.id }}"
                product-type="{{ product.type }}"
                class="murshd-add-btn">
            </salla-add-product-button>
        </div>
    </div>
</div>
