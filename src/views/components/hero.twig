{# Hero Section Component #}
<section class="hero">
    <div class="container">
        <div class="hero-inner">
            <div class="hero-content">
                <div class="hero-badge">
                    <i class="ri-sparkle-line"></i>
                    <span>منتجات رقمية احترافية</span>
                </div>
                <h1 class="hero-title">
                    اكتشف أفضل <span>المنتجات الرقمية</span> لتطوير أعمالك
                </h1>
                <p class="hero-desc">
                    نوفر لك مجموعة مختارة من القوالب، التصاميم، والأدوات الرقمية المصممة باحترافية لمساعدتك على التميز والنجاح.
                </p>
                <div class="hero-buttons">
                    <a href="/products" class="btn btn-primary btn-lg">
                        <i class="ri-shopping-bag-line"></i>
                        تصفح المنتجات
                    </a>
                    <a href="/pages/about" class="btn btn-outline btn-lg">
                        تعرف علينا
                    </a>
                </div>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-value">+500</div>
                        <div class="hero-stat-label">منتج رقمي</div>
                    </div>
                    <div>
                        <div class="hero-stat-value">+2000</div>
                        <div class="hero-stat-label">عميل سعيد</div>
                    </div>
                    <div>
                        <div class="hero-stat-value">4.9</div>
                        <div class="hero-stat-label">تقييم العملاء</div>
                    </div>
                </div>
            </div>
            <div class="hero-visual">
                <div class="hero-float-card card-1">
                    <div class="float-icon purple">
                        <i class="ri-download-cloud-line"></i>
                    </div>
                    <div>
                        <strong style="font-size:0.9rem">تحميل فوري</strong>
                        <div style="font-size:0.75rem;color:var(--text-muted)">بعد الشراء مباشرة</div>
                    </div>
                </div>
                <div class="hero-float-card card-2">
                    <div class="float-icon green">
                        <i class="ri-shield-check-line"></i>
                    </div>
                    <div>
                        <strong style="font-size:0.9rem">ضمان الجودة</strong>
                        <div style="font-size:0.75rem;color:var(--text-muted)">منتجات مراجعة بعناية</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
