<footer class="footer {{ theme.settings.get('footer_is_dark') ? 'footer--dark' : 'footer--light' }}">
    <div class="container">
        <div class="footer-grid">

            {# Brand #}
            <div class="footer-brand">
                <a href="{{ store.url }}" class="logo" aria-label="{{ store.name }}">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" class="footer-logo" width="120" height="40">
                    {% else %}
                        <span class="logo-text">{{ store.name }}</span>
                    {% endif %}
                </a>
                {% if store.description %}
                    <p class="footer-brand-desc">{{ store.description }}</p>
                {% endif %}

                {# Social Links #}
                <div class="footer-social">
                    {% if store.social.twitter %}
                        <a href="{{ store.social.twitter }}" class="social-link" aria-label="تويتر" target="_blank" rel="noreferrer noopener">
                            <i class="sicon-twitter"></i>
                        </a>
                    {% endif %}
                    {% if store.social.instagram %}
                        <a href="{{ store.social.instagram }}" class="social-link" aria-label="انستقرام" target="_blank" rel="noreferrer noopener">
                            <i class="sicon-instagram"></i>
                        </a>
                    {% endif %}
                    {% if store.social.whatsapp %}
                        <a href="{{ store.social.whatsapp }}" class="social-link" aria-label="واتساب" target="_blank" rel="noreferrer noopener">
                            <i class="sicon-whatsapp"></i>
                        </a>
                    {% endif %}
                    {% if store.social.snapchat %}
                        <a href="{{ store.social.snapchat }}" class="social-link" aria-label="سناب شات" target="_blank" rel="noreferrer noopener">
                            <i class="sicon-snapchat"></i>
                        </a>
                    {% endif %}
                    {% if store.social.youtube %}
                        <a href="{{ store.social.youtube }}" class="social-link" aria-label="يوتيوب" target="_blank" rel="noreferrer noopener">
                            <i class="sicon-youtube"></i>
                        </a>
                    {% endif %}
                </div>
            </div>

            {# Quick Links #}
            <div>
                <h4 class="footer-title">{{ trans('pages.footer.quick_links') }}</h4>
                <div class="footer-links">
                    <a href="{{ store.url }}" class="footer-link">{{ trans('pages.home.title') }}</a>
                    <a href="{{ link('products') }}" class="footer-link">{{ trans('pages.products.title') }}</a>
                    <a href="{{ link('categories') }}" class="footer-link">{{ trans('pages.categories.title') }}</a>
                    <a href="{{ link('brands') }}" class="footer-link">{{ trans('pages.brands.title') }}</a>
                </div>
            </div>

            {# Support Links #}
            <div>
                <h4 class="footer-title">{{ trans('pages.footer.support') }}</h4>
                <div class="footer-links">
                    {% for page in pages %}
                        <a href="{{ page.url }}" class="footer-link">{{ page.title }}</a>
                    {% endfor %}
                </div>
            </div>

            {# Contact #}
            <div>
                <h4 class="footer-title">{{ trans('pages.footer.contact') }}</h4>
                <div class="footer-links">
                    {% if store.contacts.email %}
                        <a href="mailto:{{ store.contacts.email }}" class="footer-link">
                            <i class="sicon-email"></i> {{ store.contacts.email }}
                        </a>
                    {% endif %}
                    {% if store.contacts.mobile %}
                        <a href="tel:{{ store.contacts.mobile }}" class="footer-link">
                            <i class="sicon-phone"></i> {{ store.contacts.mobile }}
                        </a>
                    {% endif %}
                </div>
            </div>

        </div>

        <div class="footer-bottom">
            <span>&copy; {{ "now" | date("Y") }} {{ store.name }}. {{ trans('pages.footer.all_rights') }}</span>
            <span>{{ trans('pages.footer.powered_by') }} <a href="https://salla.com" target="_blank" rel="noreferrer">سلة</a></span>
        </div>
    </div>
</footer>
